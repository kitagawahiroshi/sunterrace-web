# ============================================
# Sunterrace & Co. — Apache設定
# ============================================

# --- HTTPS強制リダイレクト ---
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# --- www → non-www リダイレクト ---
RewriteCond %{HTTP_HOST} ^www\.sunterrace\.co$ [NC]
RewriteRule ^(.*)$ https://sunterrace.co/$1 [L,R=301]

# --- セキュリティヘッダー ---
<IfModule mod_headers.c>
    # MIMEスニッフィング防止
    Header always set X-Content-Type-Options "nosniff"

    # クリックジャッキング防止
    Header always set X-Frame-Options "SAMEORIGIN"

    # リファラーポリシー
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # 権限ポリシー（カメラ・マイク・位置情報を無効化）
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

    # HSTS（1年間、HTTPS強制をブラウザに記憶させる）
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# --- キャッシュ制御 ---
<IfModule mod_headers.c>
    # HTML: キャッシュしない（常に最新を取得）
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>

    # CSS/JS: 1週間キャッシュ（?v= パラメータで無効化）
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=604800"
    </FilesMatch>

    # 画像: 1ヶ月キャッシュ
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>

    # フォント: 1年キャッシュ
    <FilesMatch "\.(woff|woff2|ttf|otf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

# --- Gzip圧縮（既にサーバー側で有効だが明示的に指定） ---
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>
